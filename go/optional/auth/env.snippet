
# --- auth module ---------------------------------------------------------
# Admin account used by bin/login and bootstrapped by scripts/setup_admin.sh.
# On first run setup_admin.sh replaces the ADMIN_PASS placeholder with a
# generated password, then sets it on the seeded admin row. ADMIN_EMAIL must
# match the seeded row in create_tables.sql.
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=change-me
# Base URL bin/login posts credentials to.
API_URL=http://localhost:8080
