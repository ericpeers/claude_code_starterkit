# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# Postgres connection string (server + test suite).
# On first run, setup_dev.sh creates a role + database for the current user and
# rewrites this line. For a role that already exists it asks for the existing
# password instead of resetting it. The database name defaults to the project
# directory name (scaffolding may have already set it here); while it is still
# the "app" placeholder, setup_dev.sh prompts to confirm it.
PG_URL=postgres://user:password@localhost:5432/app

# Secret used to sign/verify auth tokens.
# setup_dev.sh replaces this placeholder with a generated secret on first run.
JWT_SECRET=change-me

# Log verbosity: debug | info | warn | error
# Drives logrus's level at startup; also filters the GinLogger request lines
# (internal/middleware), so LOGLEVEL=error hides 2xx/3xx request noise.
LOGLEVEL=info

# Serve the Swagger UI at /swagger/index.html (internal/swagger.Register).
# Enable in dev; leave off in production so the API surface isn't exposed.
ENABLE_SWAGGER=true

# Worker concurrency for background jobs.
CONCURRENCY=4

# Port to run the local server on. Default is 8080
#PORT=8080
