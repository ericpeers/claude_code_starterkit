# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# Database connection (if used).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=change-me

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Optional examples (uncomment if your project needs them) ---
# Outbound HTTP proxy for sites that require it.
# PROXY_HOST=
# PROXY_PORT=
# PROXY_USER=
# PROXY_PASSWORD=
# External API key.
# SOME_API_KEY=
